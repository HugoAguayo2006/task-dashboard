# Canvas LMS
# Tu escuela usa este dominio para Canvas:
CANVAS_BASE_URL=https://experiencia21.tec.mx

# Pega aqui el token cuando el Tec te lo genere.
# No subas este valor real a Git ni lo pongas como VITE_*.
CANVAS_ACCESS_TOKEN=

# Persistencia cloud con Supabase
# Estos valores van en Vercel/local server, nunca como VITE_*.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CHALENDAR_SYNC_ID=default
