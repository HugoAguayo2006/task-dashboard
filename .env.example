# Canvas LMS
# Tu escuela usa este dominio para Canvas:
CANVAS_BASE_URL=https://experiencia21.tec.mx

# Pega aqui el token cuando el Tec te lo genere.
# No subas este valor real a Git ni lo pongas como VITE_*.
CANVAS_ACCESS_TOKEN=

# Calendarios externos Gmail/Outlook
# Pega enlaces privados .ics, no enlaces publicos del navegador.
# Formato recomendado para Vercel:
# [{"name":"Gmail","url":"https://calendar.google.com/calendar/ical/.../basic.ics","color":"#38bdf8"},{"name":"Outlook","url":"https://outlook.office365.com/owa/calendar/.../calendar.ics","color":"#f97316"}]
CHALENDAR_EXTERNAL_CALENDAR_FEEDS=

# Token opcional para proteger el calendario .ics de Chalendar.
# Si lo configuras, usa /api/calendar/tasks.ics?token=este_valor.
CHALENDAR_ICS_TOKEN=

# Persistencia cloud con Supabase
# Estos valores van en Vercel/local server, nunca como VITE_*.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CHALENDAR_SYNC_ID=default

# URL publica del despliegue que expone /api/sync/state.
# Es segura para el frontend porque no contiene secretos.
# Usala en localhost si quieres jalar las mismas tareas que el dominio.
VITE_SYNC_API_BASE_URL=

# En Vercel, agrega aqui los origenes que podran sincronizar contra este API.
# Ejemplo: https://tu-dominio.com,http://localhost:5173
CHALENDAR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
